{% render 'page-contact-strip' %}

<section class="section section--soft">
  <div class="wrap" style="max-width:640px">
    <h2 class="center">Get in touch</h2>
    {% form 'contact' %}
      {% if form.posted_successfully? %}<p class="center text-muted">Thanks — we'll be in touch.</p>{% endif %}
      <div style="display:flex;flex-direction:column;gap:12px">
        <input type="text" name="contact[name]" placeholder="Name" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);background:#fff">
        <input type="email" name="contact[email]" placeholder="Email" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);background:#fff">
        <textarea name="contact[body]" placeholder="Message" rows="5" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);background:#fff"></textarea>
        <button class="btn btn--primary" type="submit">Send</button>
      </div>
    {% endform %}
  </div>
</section>

{% render 'page-final-cta' %}
