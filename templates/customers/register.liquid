<section class="section"><div class="wrap" style="max-width:480px">
  <h1 class="center">{{ 'customer.account.register' | t }}</h1>
  {% form 'create_customer' %}
    {{ form.errors | default_errors }}
    <input type="text" name="customer[first_name]" placeholder="First name" style="padding:14px;border-radius:12px;border:1px solid var(--color-border);width:100%;margin-bottom:12px">
    <input type="text" name="customer[last_name]" placeholder="Last name" style="padding:14px;border-radius:12px;border:1px solid var(--color-border);width:100%;margin-bottom:12px">
    <input type="email" name="customer[email]" placeholder="Email" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);width:100%;margin-bottom:12px">
    <input type="password" name="customer[password]" placeholder="Password" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);width:100%;margin-bottom:12px">
    <button type="submit" class="btn btn--primary" style="width:100%">Create account</button>
  {% endform %}
</div></section>
