<section class="section"><div class="wrap" style="max-width:480px"><h1 class="center">Activate account</h1>{% form 'activate_customer_password' %}{{ form.errors | default_errors }}<input type="password" name="customer[password]" placeholder="Password" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);width:100%;margin-bottom:12px"><input type="password" name="customer[password_confirmation]" placeholder="Confirm" required style="padding:14px;border-radius:12px;border:1px solid var(--color-border);width:100%;margin-bottom:12px"><button class="btn btn--primary" type="submit" style="width:100%">Activate</button>{% endform %}</div></section>
