<section class="section"><div class="wrap" style="max-width:880px">
  <h1>{{ 'customer.account.title' | t }}</h1>
  <p class="text-muted">Welcome back, {{ customer.name }}.</p>
  <h3>Orders</h3>
  {%- if customer.orders.size == 0 -%}
    <p class="text-muted">No orders yet.</p>
  {%- else -%}
    <table class="price-table"><thead><tr><th>Order</th><th>Date</th><th>Status</th><th>Total</th></tr></thead><tbody>
      {%- for order in customer.orders -%}
        <tr><td><a href="{{ order.customer_url }}">{{ order.name }}</a></td><td>{{ order.created_at | date: '%b %d, %Y' }}</td><td>{{ order.fulfillment_status_label }}</td><td>{{ order.total_price | money }}</td></tr>
      {%- endfor -%}
    </tbody></table>
  {%- endif -%}
  <p class="mt-4"><a href="{{ routes.account_logout_url }}" class="btn btn--secondary btn--small">Log out</a></p>
</div></section>
