<section class="hero">
  <div class="wrap hero__inner">
    <div class="hero__copy">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:24px">
        {%- if section.settings.cta1_text != blank -%}
          <a href="{{ section.settings.cta1_url }}" class="btn btn--primary">{{ section.settings.cta1_text }}</a>
        {%- endif -%}
        {%- if section.settings.cta2_text != blank -%}
          <a href="{{ section.settings.cta2_url }}" class="btn btn--secondary">{{ section.settings.cta2_text }}</a>
        {%- endif -%}
      </div>
    </div>
    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" loading="eager">
      {%- else -%}
        <div class="hero__placeholder">Add hero image</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium custom spray tans" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Healthier Glow. Flawless Confidence." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Customizable spray tan salons in Austin, Dallas, and Houston." },
    { "type": "text", "id": "cta1_text", "label": "Primary CTA text", "default": "Book Now" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA text", "default": "Choose Your Location" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA URL" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
