<section class="section">
  <div class="wrap" style="max-width:880px">
    <h1 class="center">Search</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex;gap:8px;max-width:520px;margin:0 auto 32px">
      <input name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" style="flex:1;padding:14px 18px;border:1px solid var(--color-border);border-radius:999px">
      <button class="btn btn--primary" type="submit">Search</button>
    </form>
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p class="center text-muted">{{ 'general.search.no_results_html' | t: terms: search.terms }}</p>
      {%- else -%}
        <div class="grid grid-4">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <a href="{{ item.url }}" class="card"><div class="card__body"><h3 class="card__title">{{ item.title }}</h3></div></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
