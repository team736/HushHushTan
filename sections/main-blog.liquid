<div class="page-hero">
  <div class="wrap">
    <span class="eyebrow">Journal</span>
    <h1>{{ blog.title }}</h1>
    <p>Tanning tips, aftercare, and your get glowing guide.</p>
  </div>
</div>
<section class="section">
  <div class="wrap">
    <div class="grid grid-3">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="card">
          <div class="card__media">
            {%- if article.image -%}<img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" loading="lazy">{%- endif -%}
          </div>
          <div class="card__body">
            <span class="eyebrow">{{ article.published_at | date: '%b %d, %Y' }}</span>
            <h3 class="card__title">{{ article.title }}</h3>
            <p class="card__meta">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            <div class="card__cta"><span class="btn btn--ghost">Read more →</span></div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
