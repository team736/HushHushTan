<section class="section section--lavender">
  <div class="wrap" style="max-width:640px;text-align:center">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'Stay in the know' }}</span>
    <h2>{{ section.settings.heading | default: 'Sign up for the latest deals, promotions & events' }}</h2>
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-form" style="background:#fff;border-radius:999px;padding:6px;max-width:480px;margin:24px auto 0">
        <input type="email" name="contact[email]" placeholder="Email address" required style="background:transparent;color:var(--color-text)">
        <button type="submit" class="btn btn--primary" style="margin:0">Subscribe</button>
      </div>
      {% if form.posted_successfully? %}<p class="mt-2 text-muted">Thanks for subscribing.</p>{% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
