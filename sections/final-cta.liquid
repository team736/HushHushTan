<section class="section section--lavender">
  <div class="wrap" style="text-align:center">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'Ready for your glow?' }}</span>
    <h2>{{ section.settings.heading | default: 'Book your custom tan today' }}</h2>
    <div class="btn-row mt-4">
      {%- if settings.book_austin != blank -%}<a class="btn btn--primary" href="{{ settings.book_austin }}" data-set-loc>Book Austin</a>{%- endif -%}
      {%- if settings.book_dallas != blank -%}<a class="btn btn--primary" href="{{ settings.book_dallas }}" data-set-loc>Book Dallas</a>{%- endif -%}
      {%- if settings.book_houston != blank -%}<a class="btn btn--primary" href="{{ settings.book_houston }}" data-set-loc>Book Houston</a>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
