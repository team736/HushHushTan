<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <main class="section center" style="min-height:100vh;display:flex;align-items:center;justify-content:center">
    <div class="wrap" style="max-width:480px">
      <h1>{{ shop.name }}</h1>
      <p class="text-muted">{{ shop.password_message }}</p>
      {% form 'storefront_password' %}
        <input type="password" name="password" placeholder="Password" style="padding:14px;border-radius:999px;border:1px solid var(--color-border);width:100%;margin-bottom:12px">
        <button type="submit" class="btn btn--primary" style="width:100%">Enter</button>
      {% endform %}
      {{ content_for_layout }}
    </div>
  </main>
</body>
</html>
