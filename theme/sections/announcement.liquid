{%- if section.settings.text != blank -%}
<div class="announcement">
  {%- if section.settings.link != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {%- else -%}{{ section.settings.text }}{%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Now booking in Austin, Dallas & Houston" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
