<section class="section {% if section.settings.bg == 'lavender' %}section--lavender{% elsif section.settings.bg == 'soft' %}section--soft{% endif %}">
  <div class="wrap" style="max-width:780px;text-align:center">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<div class="rte text-muted" style="font-size:1.05rem">{{ section.settings.body }}</div>{%- endif -%}
    {%- if section.settings.cta_text != blank -%}
      <div class="btn-row mt-4"><a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_text }}</a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "select", "id": "bg", "label": "Background", "options": [
      { "value": "white", "label": "White" },
      { "value": "soft", "label": "Soft" },
      { "value": "lavender", "label": "Lavender" }
    ], "default": "white" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "cta_text", "label": "CTA text" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
