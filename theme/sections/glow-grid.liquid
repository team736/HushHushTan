<section class="section section--lavender">
  <div class="wrap">
    <div class="section__head">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p class="text-muted">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="glow-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: '#' }}" class="glow-card" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          {%- if block.settings.subtitle != blank -%}<div class="price">{{ block.settings.subtitle }}</div>{%- endif -%}
          {%- if block.settings.body != blank -%}<p class="text-muted" style="font-size:.9rem;margin-top:8px;margin-bottom:0">{{ block.settings.body }}</p>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Glow grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Glow Menu" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your perfect glow" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "glow",
      "name": "Glow",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle / from price" },
        { "type": "text", "id": "body", "label": "Short description" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "glow", "settings": { "title": "Clear Glow", "subtitle": "From $40" } },
      { "type": "glow", "settings": { "title": "Custom Glow", "subtitle": "From $40" } },
      { "type": "glow", "settings": { "title": "Gold Glow", "subtitle": "From $45" } },
      { "type": "glow", "settings": { "title": "Brazilian Glow", "subtitle": "From $50" } },
      { "type": "glow", "settings": { "title": "Rapid Glow", "subtitle": "From $55" } },
      { "type": "glow", "settings": { "title": "Bye Bye Tan Line", "subtitle": "From $55" } },
      { "type": "glow", "settings": { "title": "Happy Birthday Glow", "subtitle": "From $34" } },
      { "type": "glow", "settings": { "title": "Partial Body", "subtitle": "From $5" } }
    ]
  },
  "presets": [{ "name": "Glow grid" }]
}
{% endschema %}
