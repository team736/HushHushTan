{%- if cart.item_count == 0 -%}
  <p class="text-muted">{{ 'general.cart.empty' | t }}</p>
  <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary mt-2" style="width:100%">{{ 'general.cart.continue_shopping' | t }}</a>
{%- else -%}
  <form action="{{ routes.cart_url }}" method="post" novalidate>
    {%- for item in cart.items -%}
      <div class="cart-item">
        {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">{%- endif -%}
        <div class="ci-body">
          <a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a>
          <div class="text-muted" style="font-size:.85rem">{{ item.variant.title }}</div>
          <div>{{ item.final_price | money }} × {{ item.quantity }}</div>
          <a href="{{ item.url_to_remove }}" class="text-muted" style="font-size:.8rem">{{ 'general.cart.remove' | t }}</a>
        </div>
      </div>
    {%- endfor -%}
    <div class="cart-foot">
      <div class="row"><span>{{ 'general.cart.subtotal' | t }}</span><span>{{ cart.total_price | money }}</span></div>
      <button type="submit" name="checkout" class="btn btn--primary" style="width:100%">{{ 'general.cart.checkout' | t }}</button>
    </div>
  </form>
{%- endif -%}
