<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Gift card</title>{{ 'base.css' | asset_url | stylesheet_tag }}</head><body><section class="section center"><div class="wrap" style="max-width:520px"><h1>{{ shop.name }} Gift Card</h1><p class="text-muted">{{ gift_card.balance | money }}</p><p><strong>{{ gift_card.code | format_code }}</strong></p>{% if gift_card.qr_identifier %}{{ gift_card | img_tag }}{% endif %}<p class="mt-4"><a class="btn btn--primary" href="{{ shop.url }}">Visit shop</a></p></div></section></body></html>
